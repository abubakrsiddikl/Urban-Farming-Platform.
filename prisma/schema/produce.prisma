model Produce {
  id                  String   @id @default(uuid())
  vendorId            String
  name                String
  description         String
  price               Float
  category            String
  certificationStatus String
  availableQuantity   Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id])
  orders Order[]
}
