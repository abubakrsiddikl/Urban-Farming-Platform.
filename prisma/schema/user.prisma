enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id        String          @id @default(uuid())
  name      String
  email     String          @unique
  password  String
  role      UserRole        @default(CUSTOMER)
  status    Status          @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  vendorProfile VendorProfile?
  orders        Order[]
  posts         CommunityPost[]
}
